---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import profile from '../assets/profile.jpg';
---

<Layout title="About — Your Name" description="Bio singkat, tools, dan fokus kerja.">
	<section class="grid gap-8 lg:grid-cols-[200px_1fr] lg:items-start">
		<div class="overflow-hidden rounded-2xl border border-ink-200 bg-white shadow-sm dark:border-ink-800 dark:bg-ink-950">
			<Image src={profile} alt="Foto profil" width={800} height={800} format="webp" />
		</div>

		<div class="space-y-5">
			<h1 class="text-3xl font-semibold tracking-tight">About Me</h1>
			<p class="text-sm leading-relaxed text-ink-600 dark:text-ink-300">
				Halo, aku <strong class="text-ink-900 dark:text-ink-50">Rosyid Ifni Andriansyah</strong>. Aku seorang murid
				dari sekolah Teknik Informatika, Aku tertarik dengan Web, App dan Game Development. Kini Aku sedang mendalami
				Mobile App Development, UI Component dengan React dan Astro, dan Cyber Security.
			</p>

			<div class="space-y-2">
				<h2 class="text-sm font-semibold tracking-tight">Stacks</h2>
				<ul class="flex flex-wrap gap-2 text-xs">
					{['Astro', 'C#', 'Flutter', 'JavaScript', 'Node.js', 'Laravel', 'Tailwind', 'Python', 'Vercel'].map((t) => (
						<li class="rounded-md bg-ink-100 px-2 py-1 text-ink-700 dark:bg-ink-900/60 dark:text-ink-200">
							{t}
						</li>
					))}
				</ul>
			</div>

			<div class="space-y-2">
				<h2 class="text-sm font-semibold tracking-tight">Links</h2>
				<div class="flex flex-wrap gap-4 text-sm">
					<a
						class="text-ink-700 underline decoration-ink-300 underline-offset-4 hover:decoration-ink-700 dark:text-ink-200 dark:decoration-ink-700 dark:hover:decoration-ink-200"
						href="https://github.com/ociddaja2"
						rel="me"
					>
						GitHub->
					</a>
					<a
						class="text-ink-700 underline decoration-ink-300 underline-offset-4 hover:decoration-ink-700 dark:text-ink-200 dark:decoration-ink-700 dark:hover:decoration-ink-200"
						href="https://www.linkedin.com/in/rosyidifniandrian"
						rel="me"
					>
						LinkedIn->
					</a>
					<a
						class="text-ink-700 underline decoration-ink-300 underline-offset-4 hover:decoration-ink-700 dark:text-ink-200 dark:decoration-ink-700 dark:hover:decoration-ink-200"
						href="mailto:rosyiidrosyid1983@gmail.com"
					>
						rosyiidrosyid1983@gmail.com->
					</a>
				</div>
			</div>
		</div>
	</section>
</Layout>

