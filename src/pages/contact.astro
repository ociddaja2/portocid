---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Your Name" description="Cara menghubungi dan link sosial.">
	<section class="space-y-5">
		<h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Contact</h1>
		<p class="max-w-2xl text-sm leading-relaxed text-ink-600 dark:text-ink-300">
			Paling cepat lewat email. Kamu juga bisa cek profil sosial atau repo project.
		</p>
	</section>

	<section class="mt-10 grid gap-5 sm:gap-6 lg:grid-cols-2">
		<div class="card p-6 sm:p-8">
			<h2 class="text-base font-semibold tracking-tight">Email</h2>
			<p class="mt-2 text-sm text-ink-600 dark:text-ink-300">
				Kirim brief singkat: tujuan, scope, deadline, dan budget (kalau ada).
			</p>
			<a
				href="mailto:rosyiidrosyid1983@email.com?subject=Project%20Inquiry"
				class="btn btn-primary mt-4"
			>
				hello@example.com
			</a>
		</div>

		<div class="card p-6 sm:p-8">
			<h2 class="text-base font-semibold tracking-tight">Social</h2>
			<ul class="mt-4 space-y-3 text-sm">
				<li>
					<a
						class="text-ink-700 dark:text-ink-200"
						href="https://github.com/ociddaja2"
						rel="me"
					>
						<span class="link">GitHub</span>
					</a>
				</li>
				<li>
					<a
						class="text-ink-700 dark:text-ink-200"
						href="https://www.linkedin.com/in/rosyiid-ifni-andriansyah-82771b27b/"
						rel="me"
					>
						<span class="link">LinkedIn</span>
					</a>
				</li>
				<li>
					<a
						class="text-ink-700 dark:text-ink-200"
						href="https://x.com/ocidd05"
						rel="me"
					>
						<span class="link">X / Twitter</span>
					</a>
				</li>
			</ul>
		</div>
	</section>
</Layout>

