---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Rosyid Ifni Andriansyah">
	<section class="space-y-5">
		<h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Contact</h1>
		<p class="max-w-2xl text-sm leading-relaxed text-ink-600 dark:text-ink-300">
			Paling cepat lewat WhatsApp. Kamu juga bisa cek profil sosial atau repo project.
		</p>
	</section>

	<section class="mt-10 grid gap-5 sm:gap-6 lg:grid-cols-2">
		<div class="card p-6 sm:p-8 transition hover:-translate-y-1 hover:shadow-soft">
			<h2 class="text-base font-semibold tracking-tight">Email</h2>
			<p class="mt-2 text-sm text-ink-600 dark:text-ink-300">
				Open for freelance atau sekedar ngobrol aja persoalan koding atau hal lain yang terkait😊.
			</p>
			<a
				href="mailto:rosyiidrosyid1983@gmail.com?subject=Project%20Inquiry"
				class="btn btn-primary mt-4"
			>
				rosyiidrosyid1983@gmail.com
			</a>
		</div>

		<div class="card p-6 sm:p-8 transition hover:-translate-y-1 hover:shadow-soft">
			<h2 class="text-base font-semibold tracking-tight">Social</h2>
			<ul class="mt-4 space-y-3 text-sm">
				<li>
					<a
						class="text-ink-700 dark:text-ink-200"
						href="https://github.com/ociddaja2"
						rel="me"
					>
						<span class="link">GitHub</span>
					</a>
				</li>
				<li>
					<a
						class="text-ink-700 dark:text-ink-200"
						href="https://www.linkedin.com/in/rosyidifniandrian"
						rel="me"
					>
						<span class="link">LinkedIn</span>
					</a>
				</li>
				<li>
					<a
						class="text-ink-700 dark:text-ink-200"
						href="https://www.instagram.com/ocidd05"
						rel="me"
					>
						<span class="link">Instagram</span>
					</a>
				</li>
				<li>
					<a
						class="text-ink-700 dark:text-ink-200"
						href="https://wa.me/6281349816010"
						rel="me"
					>
						<span class="link">WhatsApp</span>
					</a>
				</li>
			</ul>
		</div>
	</section>
</Layout>

