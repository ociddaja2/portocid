---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects')).slice(0, 3);
const posts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<Layout
	title="Rosyid Ifni Andriansyah - OCID"
	ogImage="/og-image.png"
>
	<section class="relative overflow-hidden rounded-3xl border border-ink-200 bg-white p-6 shadow-sm dark:border-ink-800 dark:bg-ink-950 sm:p-10 transition hover:-translate-y-1 hover:shadow-soft">
		<div class="absolute inset-0 -z-10 bg-gradient-to-b from-ink-50 to-white dark:from-ink-950 dark:to-ink-950"></div>
		<p class="text-sm font-medium text-ink-600 dark:text-ink-300">Hi, Im</p>
		<h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl lg:text-6xl">
			Rosyid Ifni Andriansyah <span class="text-3xl">/ Ocid</span>
		</h1>
		<p class="mt-4 max-w-4xl text-base leading-relaxed text-ink-600 dark:text-ink-300">
			A Computer Science student who loves programming and specializes in front-end and full-stack development.
		</p>
		<div class="mt-6 flex flex-wrap gap-3">
			<a href="/projects" class="btn btn-primary">Projects</a>
			<a href="/contact" class="btn btn-ghost">Contact</a>
		</div>
		<div class="mt-8 flex flex-wrap gap-x-5 gap-y-2 text-xs text-ink-500 dark:text-ink-400">
			<span>Based in Indonesia</span>
			<!-- <span aria-hidden="true">·</span>
			<span>Open to freelance</span> -->
			<span aria-hidden="true">·</span>
			<a class="link" href="/blog">Write-ups</a>
		</div>
	</section>

	<section class="section grid gap-8 lg:grid-cols-2 lg:gap-12">
		<div class="space-y-3">
			<h2 class="text-lg font-semibold tracking-tight">About</h2>
			<p class="text-sm leading-relaxed text-ink-600 dark:text-ink-300">
				Im a student at SMK Telkom Banjarbaru in South Kalimantan. I am interested in web, app, and game development.
			</p>
			<a
				href="/about"
				class="inline-flex items-center text-sm font-medium text-ink-800 dark:text-ink-100"
			>
				<span class="link">Read More</span>
			</a>
		</div>
		<div class="card p-6 sm:p-8 transition hover:-translate-y-1 hover:shadow-soft">
			<h2 class="text-lg font-semibold tracking-tight">Currently Im</h2>
			<ul class="mt-3 space-y-2 text-sm text-ink-600 dark:text-ink-300">
				<li class="flex gap-2">
					<span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-ink-400 dark:bg-ink-600"></span>
					<span>Learning to build websites with React, Next.js & Astro</span>
				</li>
				<li class="flex gap-2">
					<span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-ink-400 dark:bg-ink-600"></span>
					<span>Building Mobile Apps with Flutter & Dart</span>
				</li>
				<li class="flex gap-2">
					<span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-ink-400 dark:bg-ink-600"></span>
					<span>Learning Cyber Security</span>
				</li>
			</ul>
		</div>
	</section>

	<section class="section space-y-6">
		<div class="flex items-end justify-between gap-4">
			<h2 class="text-lg font-semibold tracking-tight">Projects</h2>
			<a
				href="/projects"
				class="text-sm text-ink-600 hover:text-ink-900 dark:text-ink-300 dark:hover:text-ink-50"
			>
				<span class="link">View all</span>
			</a>
		</div>
		<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
			{projects.map((project) => <ProjectCard project={project} />)}
		</div>
	</section>

	<section class="section space-y-5">
		<div class="flex items-end justify-between gap-4">
			<h2 class="text-lg font-semibold tracking-tight">Blog</h2>
			<a
				href="/blog"
				class="text-sm text-ink-600 hover:text-ink-900 dark:text-ink-300 dark:hover:text-ink-50"
			>
				<span class="link">View all</span>
			</a>
		</div>
		<ul class="divide-y divide-ink-200 overflow-hidden rounded-2xl border border-ink-200 bg-white dark:divide-ink-800 dark:border-ink-800 dark:bg-ink-950">
			{posts.map((post) => (
				<li class="p-5 sm:p-6">
					<a
						href={`/blog/${post.slug}`}
						class="block space-y-1 rounded-xl p-3 transition hover:bg-ink-50 dark:hover:bg-ink-900/40 sm:p-4"
					>
						<p class="text-sm font-medium">{post.data.title}</p>
						<p class="text-sm text-ink-600 dark:text-ink-300">{post.data.description}</p>
					</a>
				</li>
			))}
		</ul>
	</section>

	<section class="section rounded-3xl border border-ink-200 bg-ink-50 p-6 dark:border-ink-800 dark:bg-ink-900/20 sm:p-10 transition hover:-translate-y-1 hover:shadow-soft">
		<h2 class="text-lg font-semibold tracking-tight">Let’s build something clean.</h2>
		<p class="mt-2 max-w-2xl text-sm leading-relaxed text-ink-600 dark:text-ink-300">
			Send me an email to collaborate or just chat about programming.
		</p>
		<div class="mt-4 flex flex-wrap gap-3">
			<a href="mailto:rosyiidrosyid1983@gmail.com" class="btn btn-primary">Email me</a>
			<a href="/contact" class="btn btn-ghost">Contact page</a>
		</div>
	</section>
</Layout>
